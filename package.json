{
  "name": "autofill-browser",
  "private": true,
  "version": "0.1.2",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev:extension": "pnpm --filter chrome-extension dev",
    "build:extension": "pnpm --filter chrome-extension build",
    "build:extension:unpacked": "pnpm --filter chrome-extension build:unpacked && node scripts/check-extension-unpacked-build.mjs",
    "package:extension": "node scripts/package-extension-zip.mjs",
    "package:webstore": "node scripts/package-webstore-zip.mjs",
    "assets:webstore": "node scripts/generate-webstore-assets.mjs",
    "typecheck:extension": "pnpm --filter chrome-extension typecheck",
    "test:extension": "pnpm --filter chrome-extension test",
    "dev:log-worker": "pnpm --dir apps/log-worker dev",
    "deploy:log-worker": "pnpm --dir apps/log-worker run deploy",
    "typecheck:log-worker": "pnpm --filter chrome-extension exec tsc --noEmit -p ../log-worker/tsconfig.json",
    "test:log-worker": "pnpm --filter chrome-extension exec vitest run --root ../log-worker tests/index.test.ts",
    "dev:sync-worker": "pnpm --dir apps/sync-worker dev",
    "typecheck:sync-worker": "pnpm --filter chrome-extension exec tsc --noEmit -p ../sync-worker/tsconfig.json",
    "test:sync-worker": "pnpm --dir apps/sync-worker test",
    "verify:google-sync-e2e": "node scripts/verify-google-sync-e2e.mjs",
    "agent-vault": "node scripts/agent-vault.mjs",
    "verify:agent-vault": "node scripts/verify-agent-vault-cli.mjs",
    "agvt": "cargo run --quiet --manifest-path crates/agvt/Cargo.toml --",
    "build:agvt": "cargo build --manifest-path crates/agvt/Cargo.toml",
    "test:agvt": "cargo test --manifest-path crates/agvt/Cargo.toml",
    "install:agvt": "cargo install --path crates/agvt --locked",
    "install:agvt-native-host": "scripts/install-agvt-native-host.sh",
    "setup:extension-key": "node scripts/setup-extension-key.mjs",
    "set:google-oauth-client": "node scripts/set-google-oauth-client-id.mjs",
    "sync:android-rules": "node scripts/sync-android-rules.mjs",
    "serve:test-site": "python3 -m http.server 4173 --directory ./docs/test-site"
  }
}
