{
  "extends": "plasmo/templates/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["chrome", "node"],
    "baseUrl": ".",
    "paths": {
      "~*": ["./*"]
    }
  },
  "include": [".plasmo/index.d.ts", "./**/*.ts", "./**/*.tsx"],
  "exclude": ["node_modules"]
}
