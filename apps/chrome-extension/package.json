{
  "name": "chrome-extension",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@autofill-browser/autofill-core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.29",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^29.0.2",
    "plasmo": "^0.90.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "manifest": {
    "name": "Autofill Browser",
    "description": "Cloud-synced form autofill with secure vault support.",
    "key": "",
    "permissions": [
      "activeTab",
      "storage",
      "identity",
      "identity.email",
      "clipboardWrite"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "action": {
      "default_popup": "popup.html"
    },
    "oauth2": {
      "client_id": "456050823963-n1hkblddhgbkfa4ihb1u6cgicmfvpbp5.apps.googleusercontent.com",
      "scopes": [
        "openid",
        "email",
        "profile"
      ]
    }
  },
  "alias": {
    "@autofill-browser/autofill-core": "../../packages/autofill-core/src/index.ts"
  }
}
